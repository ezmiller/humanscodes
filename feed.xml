---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
  <channel>
    <title>{{ site.title | xml_escape }}</title>
    <description>{{ site.description | xml_escape }}</description>
    <link>{{ site.url }}{{ site.baseurl }}/</link>
    <atom:link href="{{ "/feed.xml" | prepend: site.baseurl | prepend: site.url }}" rel="self" type="application/rss+xml"/>
    <pubDate>{{ site.time | date_to_rfc822 }}</pubDate>
    <lastBuildDate>{{ site.time | date_to_rfc822 }}</lastBuildDate>
    <generator>Jekyll v{{ jekyll.version }}</generator>
    {% assign posts_with_type = site.posts | map: "url" | size %}
    {% assign all_items = "" | split: "" %}
    {% for post in site.posts %}
      {% assign item = post | push: "" | first %}
      {% assign all_items = all_items | push: post %}
    {% endfor %}
    {% for quote in site.quotes %}
      {% assign all_items = all_items | push: quote %}
    {% endfor %}
    {% for link in site.links %}
      {% assign all_items = all_items | push: link %}
    {% endfor %}
    {% assign all_items = all_items | sort: "date" | reverse %}
    {% for item in all_items limit:20 %}
      <item>
        <title>{% if item.layout == "quote" %}[Quote] {{ item.source | xml_escape }}{% elsif item.layout == "link" %}[Link] {{ item.title | xml_escape }}{% else %}{{ item.title | xml_escape }}{% endif %}</title>
        <description>{{ item.content | xml_escape }}</description>
        <pubDate>{{ item.date | date_to_rfc822 }}</pubDate>
        <link>{{ item.url | prepend: site.baseurl | prepend: site.url }}</link>
        <guid isPermaLink="true">{{ item.url | prepend: site.baseurl | prepend: site.url }}</guid>
        {% for tag in item.tags %}
        <category>{{ tag | xml_escape }}</category>
        {% endfor %}
        {% for cat in item.categories %}
        <category>{{ cat | xml_escape }}</category>
        {% endfor %}
      </item>
    {% endfor %}
  </channel>
</rss>
